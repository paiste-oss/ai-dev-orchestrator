[server]
hosts = 0.0.0.0:5232
max_connections = 20
max_content_length = 10000000
timeout = 30

[auth]
type = htpasswd
htpasswd_filename = /data/users
htpasswd_encryption = bcrypt
# Delay nach fehlgeschlagenem Login (Brute-Force-Schutz)
delay = 1

[storage]
filesystem_folder = /data/collections

[logging]
level = warning
