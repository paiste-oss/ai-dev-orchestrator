# ─────────────────────────────────────────────────────────────────────────────
# .env.infisical — Bootstrap-Secrets für den Infisical-Server selbst
#
# Diese Datei wird NICHT von Infisical verwaltet — sie IST die Grundlage
# damit Infisical überhaupt starten kann (Chicken-and-Egg gelöst).
#
# Enthält nur ~5 Werte (vs. früher 30+ in .env).
# NIEMALS in Git committen — steht bereits in .gitignore.
#
# Setup:
#   cp .env.infisical.example .env.infisical
#   → Werte ausfüllen (Generierungsbefehle unten)
#   ./start.sh init
# ─────────────────────────────────────────────────────────────────────────────

# Infisical Web-URL (wo du das Admin-UI erreichst)
# Lokal: http://localhost:8080
# Mit Cloudflare Tunnel: https://secrets.baddi.ch (falls gewünscht)
INFISICAL_SITE_URL=http://localhost:8080

# Datenbank-Passwort für Infiscals eigene PostgreSQL (frei wählbar)
INFISICAL_DB_PASSWORD=

# Verschlüsselungsschlüssel — EINMALIG GENERIEREN, NIEMALS ÄNDERN:
# python3 -c "import secrets; print(secrets.token_hex(16))"
INFISICAL_ENCRYPTION_KEY=

# JWT-Secret — EINMALIG GENERIEREN, NIEMALS ÄNDERN:
# python3 -c "import secrets; print(secrets.token_hex(32))"
INFISICAL_AUTH_SECRET=

# Machine Identity Token — NACH erstem Setup in Infisical Web UI erstellen:
# ${INFISICAL_SITE_URL} → Projekt "ai-buddy" → Project Settings → Machine Identities → + Add
# Dann diesen Wert hier eintragen:
INFISICAL_TOKEN=
