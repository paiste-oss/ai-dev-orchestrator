# ==============================================================
# AI Buddy — Konfigurationsvorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# NIEMALS .env in Git committen!
# ==============================================================

# --- Datenbank ---
POSTGRES_PASSWORD=aibuddy
DATABASE_URL=postgresql+asyncpg://aibuddy:aibuddy@postgres:5432/aibuddy

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Ollama (lokal auf dem Host) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_ROUTER_MODEL=phi3
OLLAMA_CHAT_MODEL=mistral
OLLAMA_CODE_MODEL=llama3.2

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AWS Bedrock (EU/Zürich — Daten bleiben in der Schweiz) ---
# Setup: AWS Console → Bedrock → API-Schlüssel → Langfristigen Schlüssel generieren
# Region eu-central-2 (Zürich) oder eu-central-1 (Frankfurt)
USE_BEDROCK=false
AWS_BEDROCK_API_KEY=
AWS_REGION=eu-central-2

# --- External LLMs (Fallback) ---
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-proj-...

# --- ElevenLabs TTS ---
# Berechtigungen: Text zu Sprache + Stimmen (Lesen) + Benutzer (Lesen)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- Exa Web Search ---
EXA_API_KEY=...

# --- Unsplash Bildsuche (kostenlos: unsplash.com/developers → New Application) ---
UNSPLASH_ACCESS_KEY=

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=paiste-oss/ai-dev-orchestrator

# --- n8n ---
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=...
N8N_WEBHOOK_SECRET=change-me-to-a-strong-random-secret
N8N_ENCRYPTION_KEY=...
N8N_DEFAULT_CUSTOMER_ID=
N8N_DEFAULT_BUDDY_ID=

# --- Credential-Verschlüsselung ---
# Einmalig generieren: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NIEMALS nach Go-Live ändern!
CREDENTIALS_ENCRYPTION_KEY=

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/oauth/google/callback
FRONTEND_URL=http://localhost:3000

# --- JWT ---
# Einmalig generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIS_MONTHLY=price_...
STRIPE_PRICE_BASIS_YEARLY=price_...
STRIPE_PRICE_KOMFORT_MONTHLY=price_...
STRIPE_PRICE_KOMFORT_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_METABASE_URL=http://localhost:3001

# --- Wetter (n8n) ---
OPENWEATHER_API_KEY=
WEATHER_CITY=Bern
CUSTOMER_REGION=Schweiz
