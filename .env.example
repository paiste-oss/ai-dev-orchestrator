# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Dokumentation aller benötigten Secrets
#
# Diese Datei ist KEIN echtes .env — sie enthält keine Werte.
# Alle Secrets werden über Infisical verwaltet.
#
# Setup:
#   1. infisical login
#   2. infisical init  (wähle das Projekt "ai-buddy")
#   3. Füge alle unten stehenden Keys in Infisical hinzu
#   4. ./start.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Datenbank ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aibuddy:<password>@postgres:5432/aibuddy
POSTGRES_PASSWORD=

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Ollama (lokal auf dem Host) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_ROUTER_MODEL=phi3
OLLAMA_CHAT_MODEL=mistral
OLLAMA_CODE_MODEL=llama3.2

# ── KI APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# ── AWS Bedrock (Datensouveränität — Daten bleiben in EU) ────────────────────
# USE_BEDROCK=true → alle Claude-Calls laufen über AWS Frankfurt (eu-central-1)
# statt direkt zu Anthropic USA. Empfohlen für DSGVO/DSG-Konformität.
#
# Setup:
#   1. AWS IAM User erstellen (Dienst: Amazon Bedrock)
#   2. Policy: AmazonBedrockFullAccess (oder nur InvokeModel)
#   3. Region eu-central-1 (Frankfurt) aktivieren
#   4. Claude-Modelle in Bedrock aktivieren: Model Access → Claude anfordern
#
USE_BEDROCK=false
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-central-1

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=paiste-oss/ai-dev-orchestrator

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=
N8N_WEBHOOK_SECRET=
N8N_ENCRYPTION_KEY=       # AES-Key aus /n8n_data/config — NIEMALS ÄNDERN nach erstem Start
N8N_DEFAULT_CUSTOMER_ID=
N8N_DEFAULT_BUDDY_ID=

# ── Weitere n8n-Workflows ─────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
WEATHER_CITY=Bern
CUSTOMER_REGION=Schweiz

# ── Credentials-Verschlüsselung ───────────────────────────────────────────────
# Einmalig generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NIEMALS ÄNDERN nach ersten gespeicherten Credentials!
CREDENTIALS_ENCRYPTION_KEY=

# ── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.baddi.ch/v1/oauth/google/callback

# ── Frontend / URLs ───────────────────────────────────────────────────────────
FRONTEND_URL=https://baddi.ch
NEXT_PUBLIC_BACKEND_URL=https://api.baddi.ch
NEXT_PUBLIC_METABASE_URL=https://metabase.baddi.ch

# ── JWT ───────────────────────────────────────────────────────────────────────
# Einmalig generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
