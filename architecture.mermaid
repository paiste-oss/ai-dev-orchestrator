%%{init: {"theme": "dark", "themeVariables": {"fontSize": "15px"}, "flowchart": {"nodeSpacing": 40, "rankSpacing": 60}}}%%
flowchart TD

%% ── Nutzer ──────────────────────────────────────────────────────────────────
USER(["👤 Kunde / Admin"])

%% ── Zugang ──────────────────────────────────────────────────────────────────
subgraph ENTRY["🌐 Zugang"]
  direction LR
  CF["☁️ Cloudflare Tunnel\nbaddi.ch · api.baddi.ch"]
  FE["🖥️ Frontend\nNext.js · App Router\n/chat · /settings · /admin"]
end

USER -->|HTTPS| CF
CF --> FE
CF -->|API| BE

%% ── Backend ─────────────────────────────────────────────────────────────────
subgraph BE["⚙️ Backend  (FastAPI :8000)"]
  direction LR

  subgraph API_AUTH["Auth & Profil"]
    A1["POST /auth/login\nPOST /auth/register\nPOST /auth/verify-2fa\nPOST /auth/2fa/*"]
  end

  subgraph API_CHAT["Chat"]
    A2["POST /chat/message\nGET /chat/history\nGET /chat/memories"]
  end

  subgraph API_ADMIN["Admin"]
    A3["customers · analytics\ntools · integrations\nsystem-prompts · llm"]
  end

  subgraph API_OTHER["Weitere"]
    A4["billing · documents\ndev-tasks · events (SSE)\ncredentials · workflows"]
  end
end

FE -->|JWT Bearer| BE

%% ── Services ────────────────────────────────────────────────────────────────
subgraph SVC["🔧 Services"]
  direction LR

  S_CHAT["Chat-Pipeline\n1. History + Memories\n2. System-Prompt\n3. Content Guard\n4. Tool Use (Claude)\n5. Billing"]

  S_MEM["Gedächtnis\nmemory_vector_store\nQdrant (Vektoren)\n+ PostgreSQL Fallback"]

  S_NOTIFY["📣 notification_service\nSMS via Twilio\nE-Mail via SMTP\n(je nach Kundenpräferenz)"]

  S_TOOLS["Tool Registry\nWetter · SBB · Suche\nWeb Fetch · Bilder\nSMTP · Slack · Twilio"]

  S_BILL["Billing\nStripe Checkout\nWallet · Auto-Topup\nToken-Abrechnung"]

  S_2FA["2FA\nOTP via Twilio SMS\nRedis TTL 10 Min\nTemp-JWT 5 Min"]
end

A2 --> S_CHAT
A1 --> S_2FA
S_CHAT --> S_MEM
S_CHAT --> S_TOOLS
A4 --> S_BILL

%% ── Celery Tasks ─────────────────────────────────────────────────────────────
subgraph TASKS["🔄 Celery Tasks"]
  direction LR
  T1["Memory Manager\nnach jedem Chat ≥20 Zeichen\nFakten + Stil via Claude Haiku\n→ Qdrant + PostgreSQL"]
  T2["Stock Alerts\nalle 15 Min\nKurs-Schwellwert prüfen"]
  T3["Training Reminders\nalle 5 Min\nWochenplan-Check"]
  T4["Dev Task Processor\nalle 30s\nCode-Implementierung via Claude"]
end

S_CHAT -.->|async| T1
T2 & T3 -->|Benachrichtigung| S_NOTIFY

%% ── Daten ────────────────────────────────────────────────────────────────────
subgraph DATA["🗄️ Daten  (Docker lokal)"]
  direction LR
  PG[("PostgreSQL :5432\ncustomers · chat_messages\nmemory_items · billing\ndocuments · dev_tasks")]
  RD[("Redis :6379\nBaddi-Config · Chat-Verlauf\n2FA-OTPs · Celery Queue")]
  QD[("Qdrant :6333\ncustomer_memories\ncustomer_documents")]
end

SVC --> DATA
TASKS --> DATA

%% ── Externe Dienste ──────────────────────────────────────────────────────────
subgraph EXT["☁️ Externe Dienste"]
  direction LR
  E1["Anthropic / Bedrock EU\nClaude Haiku + Sonnet\nChat · Memory · Dev"]
  E2["Twilio\nSMS 2FA\nBenachrichtigungen\n(Sender: Baddi)"]
  E3["Stripe\nAbo · Checkout\nWebhooks"]
  E4["n8n :5678\nWorkflow-Automation\nE-Mail · Calendar · Sheets"]
  E5["Ollama :11434\nnomic-embed-text\nEmbeddings (Qdrant)"]
  E6["SBB · Exa · OpenWeather\nJina · ElevenLabs\nOpenAI (DALL-E · Whisper)"]
end

S_CHAT --> E1
T1 --> E1
T4 --> E1
S_2FA --> E2
S_NOTIFY --> E2
S_BILL --> E3
S_TOOLS --> E4
S_MEM --> E5
S_TOOLS --> E6

%% ── Styling ───────────────────────────────────────────────────────────────────
classDef fe    fill:#1e3a5f,stroke:#3b82f6,color:#93c5fd
classDef be    fill:#1a2e1a,stroke:#22c55e,color:#86efac
classDef svc   fill:#2d1b4e,stroke:#a855f7,color:#d8b4fe
classDef data  fill:#3b1f1f,stroke:#ef4444,color:#fca5a5
classDef task  fill:#1a2a3a,stroke:#38bdf8,color:#7dd3fc
classDef ext   fill:#292014,stroke:#f59e0b,color:#fcd34d
classDef infra fill:#2a2a1a,stroke:#eab308,color:#fde047

class FE,ENTRY fe
class BE,API_AUTH,API_CHAT,API_ADMIN,API_OTHER,A1,A2,A3,A4 be
class SVC,S_CHAT,S_MEM,S_NOTIFY,S_TOOLS,S_BILL,S_2FA svc
class DATA,PG,RD,QD data
class TASKS,T1,T2,T3,T4 task
class EXT,E1,E2,E3,E4,E5,E6 ext
class CF infra
