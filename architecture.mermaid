%% ════════════════════════════════════════════════════════════════
%% CELERY TASKS
%% ════════════════════════════════════════════════════════════════

subgraph TASKS["🔄 Celery Tasks  (background)"]
  direction LR
  T_MM["memory_manager.py\n↳ nach jedem Chat\nNur USER-Nachrichten\nDedup via get_all_memories()\nOllama → Fakten → Qdrant + PG"]
  T_DEV["dev_task_processor.py\n↳ alle 30s\nDevTask-Queue\n→ Claude implementiert Code"]
  T_SUM["summaries.py\n↳ täglich 20:00\nClaude Haiku (httpx direkt)"]
  T_REM["reminders.py\n↳ on-demand"]
end

subgraph CELERY_INFRA["Celery Infrastruktur"]
  direction LR
  CWORKER["ai_celery_worker\nTask-Ausführung"]
  CBEAT["ai_celery_beat\nScheduler"]
end

CF12 -.->|async| TASKS
TASKS --> CWORKER
CBEAT --> TASKS
T_MM --> E_OLLAMA

%% ════════════════════════════════════════════════════════════════
%% DATENBANKEN
%% ════════════════════════════════════════════════════════════════

subgraph DB["🗄️  Datenbanken  (lokal · Docker)"]
  direction LR

  subgraph PG["PostgreSQL  :5432"]
    PG1["customers\nsubscription_plans\nwallet (balance · limits · auto-topup)"]
    PG2["ai_buddies · buddy_events"]
    PG3["chat_messages · memory_items"]
    PG4["dev_tasks · capability_requests"]
    PG5["payments · invoice_counter · cost_entries"]
    PG6["customer_documents · credentials · n8n_workflows"]
  end

  subgraph REDIS["Redis  :6379"]
    R1["DB 0 — App\nbaddi:config · uhrwerk:config\nmemory_manager:config\nagent:system_prompt:*\nchat:recent:{id}\nrouter:learned:{intent}"]
    R2["DB 1 — Celery Broker\nTask-Queue"]
    R3["DB 3 — Infisical Session-Store"]
  end

  subgraph QDRANT["Qdrant  :6333"]
    Q1["customer_memories\n768d · COSINE"]
    Q2["customer_documents\n768d · COSINE"]
  end
end

%% ════════════════════════════════════════════════════════════════
%% DEV-PIPELINE
%% ════════════════════════════════════════════════════════════════

subgraph DEV["🛠️  Dev-Pipeline  (Selbstentwickelndes Uhrwerk)"]
  direction LR
  D_CAPGAP["CapabilityRequest\nKunde meldet Bedarf"]
  D_ENTW["entwicklung_engine.py\nAnalyse + Planung"]
  D_DEVTASK["DevTask Queue\n(PostgreSQL)"]
  D_CLAUDE["Claude\nimplementiert Code"]
  D_GIT["Git Auto-Push\nbei Abschluss"]
  D_CAPGAP --> D_ENTW --> D_DEVTASK --> D_CLAUDE --> D_GIT
end

A_ENTW --> DEV
T_DEV --> D_CLAUDE

