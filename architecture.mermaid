  "theme": "dark",
  "themeVariables": {
    "fontSize": "18px",
    "fontFamily": "Inter, Segoe UI, sans-serif"
  },
  "flowchart": {
    "nodeSpacing": 40,
    "rankSpacing": 60,
    "htmlLabels": true
  }
}}%%
flowchart TD

%% ════════════════════════════════════════════════════════════════
%% EXTERNE ZUGÄNGE
%% ════════════════════════════════════════════════════════════════

    USER(["👤 Kunde / Admin\nbrowser"])
    VERCEL["☁️ Vercel\nNext.js Frontend\nbaddi.ch"]
    CF["🌐 Cloudflare Tunnel\napi.baddi.ch → :8000\nbaddi.ch  → :3000"]

    USER -->|HTTPS| CF
    CF --> VERCEL
    CF --> BACKEND_ENTRY

%% ════════════════════════════════════════════════════════════════
%% FRONTEND — SEITEN
%% ════════════════════════════════════════════════════════════════

subgraph FE["🖥️  Frontend  (Next.js / Vercel)"]
    direction LR

    subgraph FE_AUTH["Auth"]
        FP_LOGIN["/login"]
        FP_REG["/register"]
    end

    subgraph FE_USER["Kundenbereich"]
        FP_CHAT["/chat/[buddyId]\nBaddi-Chat"]
        FP_BILLING["/user/billing\nAbos & Tokens"]
        FP_PORTAL["/user/silberperlen\n/bestager / /youngsters…"]
    end

    subgraph FE_ADMIN["Admin-Bereich"]
        FP_CUST["/admin/customers\n+/[id]"]
        FP_BADDIS["/admin/baddis\n+/[id]"]
        FP_ENTW["/admin/entwicklung\n+/[id]"]
        FP_DEVTOOL["/admin/devtool"]
        FP_FINANCE["/admin/finanzen"]
        FP_UHRWERK["/admin/uhrwerk"]
        FP_WF["/admin/workflows"]
        FP_CELERY["/admin/workflows/celery"]
    end

    subgraph FE_COMP["Komponenten"]
        C_CHAT["BaddiChat.tsx"]
        C_AVATAR["BuddyAvatar.tsx\nAvatarCreatorModal.tsx"]
        C_SIDEBAR["AdminSidebar.tsx"]
        C_VOICE["VoiceButton.tsx"]
        C_FILES["FileDropZone.tsx"]
    end
end

VERCEL --- FE

%% ════════════════════════════════════════════════════════════════
%% BACKEND — FASTAPI
%% ════════════════════════════════════════════════════════════════

    BACKEND_ENTRY["main.py\nFastAPI :8000\nCORS · Lifespan · Router"]

subgraph API["🔌 API  (backend/api/v1/)"]
    direction TB
    A_AUTH["auth.py\nPOST /login\nPOST /register\nGET /me"]
    A_CHAT["chat.py\nPOST /chat/message\nGET /chat/history\nGET /chat/memories"]
    A_BILD["billing.py\nGET /plans\nPOST /checkout\nPOST /topup\nPOST /webhook"]
    A_CUST["customers.py\nCRUD /customers/{id}"]
    A_BUDDY["buddies.py\nCRUD /buddies\nPATCH /avatar"]
    A_DOC["documents.py\nPOST /upload\nPOST /search"]
    A_ENTW["entwicklung.py\nGET /entwicklung\nPOST /{id}/implement"]
    A_DEV["dev_tasks.py\nCRUD /dev-tasks\nPOST /run-now"]
    A_EVT["events.py\nSSE /agent/events/stream\nPOST /agent/event"]
    A_WF["workflows.py\nTrigger n8n services"]
    A_FIN["finance.py\nGET /costs\nGET /revenue"]
    A_SET["settings.py\nGET/PUT /baddi/{id}\nGET /uhrwerk"]
    A_CRED["credentials.py\nGET/PUT /credentials"]
    A_TRANSP["transport.py\nSBB API"]
end

BACKEND_ENTRY --> API

%% ════════════════════════════════════════════════════════════════
%% KERN-FLOW: CHAT-ANFRAGE
%% ════════════════════════════════════════════════════════════════

subgraph CHAT_FLOW["💬 Chat-Flow  (pro Nachricht)"]
    direction TB
    CF1["1. History laden\n(PostgreSQL, 20 Msg)"]
    CF2["2. Baddi-Config\n(Redis: baddi:config:{id})"]
    CF3["3. Memories laden\n(Qdrant Vektor-Suche)"]
    CF4["4. System-Prompt bauen"]
    CF5["5. ROUTER\nagent_router.py"]
    CF6["6. Router-Gedächtnis\n(Redis: router:learned:{intent})"]
    CF7["7. Uhrwerk / Tools\n(n8n + Tool Registry)"]
    CF8["8. Bewertung\nassess_response()"]
    CF9["9. LLM-Aufruf\nllm_gateway.py"]
    CF10["10. Persistieren\n(PostgreSQL)"]
    CF11["11. Token-Billing\n(Stripe)"]
    CF12["12. Memory Manager\n(Celery → Hintergrund)"]

    CF1 --> CF2 --> CF3 --> CF4 --> CF5
    CF5 --> CF6
    CF5 --> CF7
    CF7 --> CF8
    CF8 -->|Gap| CF5
    CF8 -->|OK| CF9
    CF9 --> CF10 --> CF11 --> CF12
end

A_CHAT --> CHAT_FLOW

%% ════════════════════════════════════════════════════════════════
%% SERVICES
%% ════════════════════════════════════════════════════════════════

subgraph SVC["⚙️  Services  (backend/services/)"]
    direction LR

    subgraph SVC_AI["KI & Routing"]
        S_ROUTER["agent_router.py\nStage 0 Content Guard\nKeyword → Memory → Tools → Assess"]
        S_GW["llm_gateway.py\nClaude → Gemini → OpenAI\nChatResult (text + tokens)"]
        S_BUDDY["buddy_agent.py\nAnthropic Tool Use\nTool-Loop"]
        S_ENTW["entwicklung_engine.py\nCapability-Analyse\nTool-Planung"]
    end

    subgraph SVC_MEM["Gedächtnis"]
        S_MEM["memory_service.py\nselect_relevant_context()\nQdrant → PG Fallback"]
        S_MVEC["memory_vector_store.py\nQdrant: customer_memories\nOllama Embeddings"]
        S_VDOC["vector_store.py\nQdrant: customer_documents\nnomic-embed-text 768d"]
        S_RMEM["router_memory.py\nRedis: router:learned\nErfolg/Misserfolg"]
    end

    subgraph SVC_INT["Integrationen"]
        S_N8N["n8n_client.py\nWebhook-Trigger"]
        S_SBB["sbb_client.py\nSBB Transport API"]
        S_TOOLS["tool_registry.py\nTool-Katalog"]
        S_CRED["credential_service.py\nFernet-Verschlüsselung"]
        S_BILL["billing_service.py\nStripe Checkout\nWebhook · Quota · VAT"]
        S_FILE["file_parser.py\nPDF · DOCX · XLSX"]
        S_EVT["buddy_event_service.py\nSSE via Redis Pub/Sub"]
    end
end

CF5 --> S_ROUTER
CF9 --> S_GW
CF3 --> S_MEM
S_MEM --> S_MVEC
CF12 -.->|async| TASKS

%% ════════════════════════════════════════════════════════════════
%% CELERY TASKS
%% ════════════════════════════════════════════════════════════════

subgraph TASKS["🔄 Celery Tasks  (background)"]
    direction LR
    T_MM["memory_manager.py\n↳ nach jedem Chat\nOllama → Fakten\n→ Qdrant + PostgreSQL"]
    T_DEV["dev_task_processor.py\n↳ alle 30s\nDevTask-Queue\n→ Claude implementiert Code"]
    T_SUM["summaries.py\n↳ täglich 20:00\nProjekt-Zusammenfassung"]
    T_REM["reminders.py\n↳ on-demand\nProaktive Nachrichten"]
end

subgraph CELERY_INFRA["Celery Infrastruktur"]
    CWORKER["ai_celery_worker\nTask-Ausführung"]
    CBEAT["ai_celery_beat\nScheduler"]
end

TASKS --> CWORKER
CBEAT --> TASKS

%% ════════════════════════════════════════════════════════════════
%% DATENBANKEN & STORAGE
%% ════════════════════════════════════════════════════════════════

subgraph DB["🗄️  Datenbanken"]
    direction TB

    subgraph PG["PostgreSQL  (ai_postgres :5432)"]
        PG1["customers\nsubscription_plans"]
        PG2["ai_buddies\nbuddy_tools\nbuddy_events"]
        PG3["chat_messages\nmemory_items"]
        PG4["dev_tasks\ncapability_requests"]
        PG5["payments\ninvoice_counter\ncost_entries"]
        PG6["customer_documents\ncustomer_credentials\nn8n_workflows"]
    end

    subgraph REDIS["Redis  (ai_redis :6379)"]
        R1["DB 0 — App\nbaddi:config:{id}\nchat:recent:{id}\nrouter:learned:{intent}"]
        R2["DB 1 — Celery Broker\nTask-Queue"]
        R3["DB 3 — Infisical\nSession-Store"]
        R4["devtask:output:{id}\nSSE Pub/Sub"]
    end

    subgraph QDRANT["Qdrant  (ai_qdrant :6333)"]
        Q1["customer_memories\nFakten-Vektoren\n768d · COSINE"]
        Q2["customer_documents\nDokument-Chunks\n768d · COSINE"]
    end
end

%% ════════════════════════════════════════════════════════════════
%% EXTERNE DIENSTE
%% ════════════════════════════════════════════════════════════════

subgraph EXT["🌍 Externe Dienste"]
    direction LR
    E_CLAUDE["Anthropic\nClaude Haiku 4.5\n(primär)"]
    E_GEMINI["Google\nGemini 2.5 Flash\n(Fallback 1)"]
    E_OPENAI["OpenAI\nGPT-4o-mini\n(Fallback 2)"]
    E_OLLAMA["Ollama  (lokal)\nphi3 · mistral\nnomic-embed-text\nMemory + Routing"]
    E_N8N["n8n  (:5678)\nE-Mail · SMS · Slack\nCalendar · Sheets"]
    E_STRIPE["Stripe\nCheckout · Webhooks\nAbo-Verwaltung · VAT"]
    E_SBB["SBB API\nÖV-Auskunft"]
    E_RPM["Ready Player Me\nAvatar-Creator"]
    E_INFISICAL["Infisical  (:8080)\nSecrets Manager\nalle Env-Vars"]
    E_METABASE["Metabase  (:3001)\nBI-Dashboard"]
    E_BREVO["Brevo SMTP\nE-Mail-Versand"]
end

S_GW --> E_CLAUDE
S_GW --> E_GEMINI
S_GW --> E_OPENAI
T_MM --> E_OLLAMA
S_MVEC --> E_OLLAMA
S_VDOC --> E_OLLAMA
S_N8N --> E_N8N
S_BILL --> E_STRIPE
S_SBB --> E_SBB
A_BILD --> E_STRIPE
E_N8N --> E_BREVO

%% ════════════════════════════════════════════════════════════════
%% VERBINDUNGEN: API → SERVICES → DB
%% ════════════════════════════════════════════════════════════════

A_CHAT --> S_GW
A_CHAT --> S_ROUTER
A_BILD --> S_BILL
A_DOC --> S_FILE
A_DOC --> S_VDOC
A_ENTW --> S_ENTW
A_DEV --> T_DEV
A_EVT --> S_EVT

SVC --> PG
SVC --> REDIS
S_MVEC --> Q1
S_VDOC --> Q2

T_MM --> Q1
T_MM --> PG3
T_DEV --> PG4

E_INFISICAL -.->|injects secrets| BACKEND_ENTRY

%% ════════════════════════════════════════════════════════════════
%% ENTWICKLUNG & DEPLOYMENT
%% ════════════════════════════════════════════════════════════════

subgraph DEV["🛠️  Dev-Pipeline"]
    D_CAPGAP["CapabilityRequest\nKunde meldet Bedarf"]
    D_ENTW["entwicklung_engine.py\nAnalyse + Planung"]
    D_DEVTASK["DevTask Queue\n(PostgreSQL)"]
    D_CLAUDE["Claude implementiert\nCode via Prompt"]
    D_GIT["Git Auto-Push\nbei Abschluss"]

    D_CAPGAP --> D_ENTW --> D_DEVTASK --> D_CLAUDE --> D_GIT
end

A_ENTW --> DEV
T_DEV --> D_CLAUDE

