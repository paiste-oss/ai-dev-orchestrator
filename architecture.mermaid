%% BILLING — mit Stripe direkt daneben
%% ════════════════════════════════════════════════════════════════

subgraph SVC_BILL["💳 Billing"]
  S_BILL["billing_service.py\nStripe Checkout · Webhook\nWallet · Auto-Topup · VAT"]

  subgraph BILLING_MODEL["Bezahlmodell"]
    direction LR
    B_ABO["Abo (Stripe)\nPersonal · Intensiv · Premium\nMonatlich / Jährlich"]
    B_WALLET["Prepaid-Wallet\ntoken_balance_chf\nAuto-Topup (Karte)"]
    B_BANK["Banküberweisung\nBAD-{6CHAR}-{MMDDHHMM}\nAdmin bestätigt manuell"]
    B_OVERAGE["Token-Overage\nCHF/1k Tokens\nnach Inklusiv-Kontingent"]
  end
