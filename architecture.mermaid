flowchart TD

%% ════════════════════════════════════════════════════════════════
%% ZUGANG
%% ════════════════════════════════════════════════════════════════

USER(["👤 Kunde / Admin\nbrowser"])

subgraph ENTRY["🌐 Zugang"]
  direction LR
  CFTUNNEL["☁️ Cloudflare Tunnel\nbaddi.ch → :3000\napi.baddi.ch → :8000"]
  subgraph EXT_DEPLOY["Externer Dienst"]
    VERCEL["Vercel\nNext.js Deploy"]
  end
end

USER -->|HTTPS| CFTUNNEL
CFTUNNEL --> VERCEL
CFTUNNEL --> BACKEND_ENTRY

%% ════════════════════════════════════════════════════════════════
%% FRONTEND
%% ════════════════════════════════════════════════════════════════

subgraph FE["🖥️  Frontend  (Next.js)"]
  direction LR

  subgraph FE_AUTH["Auth"]
    FP_LOGIN["/login"]
    FP_REG["/register"]
  end

  subgraph FE_USER["Kundenbereich"]
    FP_CHAT["/chat\nBaddi-Chat · Voice · Kamera\nBild- & Video-Upload · ElevenLabs TTS\nstripMarkdown vor Sprachausgabe"]
    FP_BILLING["/user/billing\nAbos & Tokens"]
    FP_WALLET["/user/wallet\nPrepaid-Guthaben"]
    FP_SETTINGS["/user/settings\nProfil · Sprache · Passwort"]
  end

  subgraph FE_ADMIN["Admin-Bereich"]
    FP_CUST["/admin/customers + /[id]"]
    FP_BADDIS["/admin/baddis + /[id]"]
    FP_ENTW["/admin/entwicklung + /[id]"]
    FP_DEVTOOL["/admin/devtool"]
    FP_FINANCE["/admin/finanzen"]
    FP_ROUTER["/admin/router\nTools · Intents · Gedächtnis\nSystem-Prompt Vorschau"]
    FP_WF["/admin/workflows"]
    subgraph FP_UHRWERK_GRP["Uhrwerk"]
      FP_LLM["/admin/uhrwerk/llm\nLokale & externe LLMs\nInstall · Update-Check"]
      FP_SYSPROMPT["/admin/uhrwerk/system-prompts\n6 Agenten editierbar\nbaddi · uhrwerk · memory\nrouter · task_runner · entwicklung"]
    end
  end

  subgraph FE_COMP["Komponenten"]
    C_VOICE["VoiceButton.tsx\nWeb Speech API"]
    C_FILES["FileDropZone.tsx\nDrag & Drop\nBilder · Videos · Dokumente"]
    C_AVATAR["BuddyAvatar.tsx"]
    C_SIDEBAR["AdminSidebar.tsx\nRouter · LLM · System-Prompts"]
  end

  subgraph EXT_AVATAR["Externer Dienst"]
    E_RPM["Ready Player Me\nAvatar-Creator"]
  end
end

VERCEL --- FE
C_AVATAR --> E_RPM

%% ════════════════════════════════════════════════════════════════
%% BACKEND ENTRY + SECRETS
%% ════════════════════════════════════════════════════════════════

BACKEND_ENTRY["⚙️ main.py\nFastAPI :8000 (no docs)\nCORS · Lifespan · Router"]

subgraph EXT_SECRETS["Externer Dienst"]
  E_INFISICAL["🔐 Infisical :8080\nSecrets Manager\nalle API Keys"]
end

E_INFISICAL -.->|injects secrets| BACKEND_ENTRY

%% ════════════════════════════════════════════════════════════════
%% API
%% ════════════════════════════════════════════════════════════════

subgraph API["🔌 API  (backend/api/v1/)"]
  direction LR
  A_AUTH["auth.py\nPOST /login · /register\nGET /me · POST /change-password"]
  A_CHAT["chat.py\nPOST /message · /transcribe · /tts\nGET /history · /memories\nDELETE /memories/{id}"]
  A_BILD["billing.py\nGET /plans · /wallet\nPOST /checkout · /topup · /webhook"]
  A_CUST["customers.py\nCRUD /{id}\nPATCH /me · DELETE /me/memory-consent"]
  A_BUDDY["buddies.py\nCRUD /buddies · PATCH /avatar"]
  A_DOC["documents.py\nPOST /upload · /search"]
  A_ENTW["entwicklung.py\nCapability Requests"]
  A_DEV["dev_tasks.py\nCRUD · POST /run-now"]
  A_EVT["events.py\nSSE /agent/events/stream"]
  A_FIN["finance.py\nGET /costs · /revenue"]
  A_SET["settings.py\nGET/PUT /baddi/{id}"]
  A_CRED["credentials.py\nGET/PUT /credentials"]
  A_RADMIN["router_admin.py\nGET /admin/router/overview\n/memory · /system-prompt"]
  A_LLMADMIN["llm_admin.py\nGET /admin/llm/overview\nPOST /pull · /check-updates"]
  A_SYSADMIN["system_prompts_admin.py\nGET /admin/system-prompts\nPUT /admin/system-prompts/{key}"]
end

BACKEND_ENTRY --> API

%% ════════════════════════════════════════════════════════════════
%% CHAT FLOW
%% ════════════════════════════════════════════════════════════════

subgraph CHAT_FLOW["💬 Chat-Flow  (pro Nachricht)"]
  direction TB
  CF1["1. History laden\n(PostgreSQL · 20 Msg)"]
  CF2["2. Baddi-Config\n(Redis: baddi:config)"]
  CF3["3. Memories\n(Qdrant Vektor-Suche)"]
  CF4["4. System-Prompt bauen"]
  CF5["5. ROUTER\nagent_router.py"]
  CF6["6. Router-Gedächtnis\n(Redis: router:learned)"]
  CF7["7. Uhrwerk / Tools\n(Tool Registry)"]
  CF8["8. assess_response()\nGap nur bei echten Fähigkeitslücken\n(nicht bei Tool-Fehlern)"]
  CF9["9. LLM-Aufruf\nllm_gateway.py"]
  CF10["10. Persistieren\n(PostgreSQL)"]
  CF11["11. Token-Billing\n(Wallet)"]
  CF12["12. Memory Manager\n(Celery async)"]

  CF1 --> CF2 --> CF3 --> CF4 --> CF5
  CF5 --> CF6
  CF5 --> CF7
  CF7 --> CF8
  CF8 -->|Gap| CF5
  CF8 -->|OK| CF9
  CF9 --> CF10 --> CF11 --> CF12
end

A_CHAT --> CHAT_FLOW

%% ════════════════════════════════════════════════════════════════
%% KI & ROUTING — mit LLM-Diensten direkt daneben
%% ════════════════════════════════════════════════════════════════

subgraph SVC_AI["⚡ KI & Routing"]
  S_ROUTER["agent_router.py\nContent Guard · Keyword-Matching\nIntents: transport · web_fetch · web_search\nimage_input · image_generation\ndocument · email · calendar"]
  S_GW["llm_gateway.py\nClaude → Gemini → OpenAI\nChatResult (text + tokens)"]
  S_BUDDY["buddy_agent.py\nAnthropic Tool Use\nTool-Loop (max 5 Runden)\nTool-Result Logging"]
  S_ENTW["entwicklung_engine.py\nCapability-Analyse · Tool-Planung"]
  S_EL["elevenlabs_client.py\nText → audio/mpeg\neleven_multilingual_v2"]
end

subgraph EXT_LLM["Externer Dienst"]
  direction LR
  E_CLAUDE["Anthropic\nClaude Haiku 4.5\n(primär · Vision)"]
  E_GEMINI["Google\nGemini 2.5 Flash\n(Fallback 1)"]
  E_OPENAI_LLM["OpenAI\nGPT-4o-mini\n(Fallback 2)"]
end

CF5 --> S_ROUTER
CF9 --> S_GW
S_GW --> E_CLAUDE
S_GW --> E_GEMINI
S_GW --> E_OPENAI_LLM
A_CHAT -->|POST /tts| S_EL

%% ════════════════════════════════════════════════════════════════
%% GEDÄCHTNIS — mit Ollama direkt daneben
%% ════════════════════════════════════════════════════════════════

subgraph SVC_MEM["🧠 Gedächtnis"]
  S_MEM["memory_service.py\nselect_relevant_context()\nQdrant → PG Fallback"]
  S_MVEC["memory_vector_store.py\nQdrant: customer_memories\n768d · COSINE\nget_all_memories() für Dedup"]
  S_VDOC["vector_store.py\nQdrant: customer_documents\nnomic-embed-text 768d"]
  S_RMEM["router_memory.py\nRedis: router:learned\nErfolg / Misserfolg"]
end

subgraph EXT_LOCAL["Externer Dienst"]
  E_OLLAMA["Ollama  (lokal :11434)\nphi3 · mistral\nnomic-embed-text\nMemory-Extraktion + Embeddings"]
end

CF3 --> S_MEM
S_MVEC --> E_OLLAMA
S_VDOC --> E_OLLAMA

%% ════════════════════════════════════════════════════════════════
%% TOOLS & INTEGRATIONEN — mit Web/AI-Diensten direkt daneben
%% ════════════════════════════════════════════════════════════════

subgraph SVC_INT["🔧 Tools & Integrationen"]
  S_TOOLS["tool_registry.py\nZentraler Tool-Katalog\nsbb_transport · web_fetch\nweb_search · image_generation"]
  S_SBB["sbb_client.py\nÖV-Verbindungen · Stationboard"]
  S_JINA["jina_client.py\nURL → Markdown\n(kein API-Key nötig)"]
  S_EXA["exa_client.py\nNeuronale Suche\nSnippets + Quellen"]
  S_N8N["n8n_client.py\nWorkflow-Trigger"]
  S_FILE["file_parser.py\nPDF · DOCX · XLSX"]
  S_EVT["buddy_event_service.py\nSSE via Redis Pub/Sub\nOllama Relevanz-Check"]
  S_CRED["credential_service.py\nFernet-Verschlüsselung"]
end

subgraph EXT_WEB["Externer Dienst"]
  direction LR
  E_SBB["SBB Transport API\nÖV-Auskunft Schweiz"]
  E_JINA["Jina Reader\nr.jina.ai"]
  E_EXA["Exa Search\napi.exa.ai"]
  E_DALLE["OpenAI\nDALL-E 3 · Whisper"]
  E_ELEVENLABS["ElevenLabs\nTTS API\neleven_multilingual_v2"]
end

S_ROUTER -->|tool_keys| S_TOOLS
S_TOOLS --> S_SBB
S_TOOLS --> S_JINA
S_TOOLS --> S_EXA
S_SBB --> E_SBB
S_JINA --> E_JINA
S_EXA --> E_EXA
S_BUDDY -->|image_generation · transcribe| E_DALLE
S_EL --> E_ELEVENLABS

