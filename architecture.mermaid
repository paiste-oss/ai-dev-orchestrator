%% STYLING
%% ════════════════════════════════════════════════════════════════

classDef frontend fill:#1e3a5f,stroke:#3b82f6,color:#93c5fd
classDef backend fill:#1a2e1a,stroke:#22c55e,color:#86efac
classDef service fill:#2d1b4e,stroke:#a855f7,color:#d8b4fe
classDef database fill:#3b1f1f,stroke:#ef4444,color:#fca5a5
classDef external fill:#1f2d1f,stroke:#84cc16,color:#bef264
classDef task fill:#1a2a3a,stroke:#38bdf8,color:#7dd3fc
classDef infra fill:#2a2a1a,stroke:#eab308,color:#fde047

class FE_AUTH,FE_USER,FE_ADMIN,FE_COMP,FP_LOGIN,FP_REG,FP_CHAT,FP_BILLING,FP_PORTAL,FP_CUST,FP_BADDIS,FP_ENTW,FP_DEVTOOL,FP_FINANCE,FP_UHRWERK,FP_WF,FP_CELERY frontend
class BACKEND_ENTRY,API,A_AUTH,A_CHAT,A_BILD,A_CUST,A_BUDDY,A_DOC,A_ENTW,A_DEV,A_EVT,A_WF,A_FIN,A_SET,A_CRED,A_TRANSP backend
class SVC,SVC_AI,SVC_MEM,SVC_INT,S_ROUTER,S_GW,S_BUDDY,S_ENTW,S_MEM,S_MVEC,S_VDOC,S_RMEM,S_N8N,S_SBB,S_TOOLS,S_CRED,S_BILL,S_FILE,S_EVT service
class DB,PG,PG1,PG2,PG3,PG4,PG5,PG6,REDIS,R1,R2,R3,R4,QDRANT,Q1,Q2 database
class EXT,E_CLAUDE,E_GEMINI,E_OPENAI,E_OLLAMA,E_N8N,E_STRIPE,E_SBB,E_RPM,E_INFISICAL,E_METABASE,E_BREVO external
class TASKS,T_MM,T_DEV,T_SUM,T_REM task
class CELERY_INFRA,CWORKER,CBEAT,CF,VERCEL infra
