%% STYLING
%% ════════════════════════════════════════════════════════════════

classDef frontend  fill:#1e3a5f,stroke:#3b82f6,color:#93c5fd
classDef backend   fill:#1a2e1a,stroke:#22c55e,color:#86efac
classDef service   fill:#2d1b4e,stroke:#a855f7,color:#d8b4fe
classDef database  fill:#3b1f1f,stroke:#ef4444,color:#fca5a5
classDef external  fill:#292014,stroke:#f59e0b,color:#fcd34d
classDef task      fill:#1a2a3a,stroke:#38bdf8,color:#7dd3fc
classDef infra     fill:#2a2a1a,stroke:#eab308,color:#fde047
classDef billing   fill:#2a1a2a,stroke:#ec4899,color:#f9a8d4

class FE_AUTH,FE_USER,FE_ADMIN,FE_COMP,FP_LOGIN,FP_REG,FP_CHAT,FP_BILLING,FP_WALLET,FP_SETTINGS,FP_CUST,FP_BADDIS,FP_ENTW,FP_DEVTOOL,FP_FINANCE,FP_ROUTER,FP_WF,FP_LLM,FP_SYSPROMPT,FP_UHRWERK_GRP frontend
class BACKEND_ENTRY,API,A_AUTH,A_CHAT,A_BILD,A_CUST,A_BUDDY,A_DOC,A_ENTW,A_DEV,A_EVT,A_FIN,A_SET,A_CRED,A_RADMIN,A_LLMADMIN,A_SYSADMIN backend
class SVC_AI,SVC_MEM,SVC_INT,S_ROUTER,S_GW,S_BUDDY,S_ENTW,S_EL,S_MEM,S_MVEC,S_VDOC,S_RMEM,S_N8N,S_SBB,S_JINA,S_EXA,S_TOOLS,S_CRED,S_FILE,S_EVT service
class DB,PG,PG1,PG2,PG3,PG4,PG5,PG6,REDIS,R1,R2,R3,QDRANT,Q1,Q2 database
class E_RPM,E_INFISICAL,E_CLAUDE,E_GEMINI,E_OPENAI_LLM,E_OLLAMA,E_SBB,E_JINA,E_EXA,E_DALLE,E_ELEVENLABS,E_N8N,E_BREVO,E_STRIPE,E_METABASE,VERCEL external
class TASKS,T_MM,T_DEV,T_SUM,T_REM task
class CELERY_INFRA,CWORKER,CBEAT,CFTUNNEL infra
class SVC_BILL,BILLING_MODEL,B_ABO,B_WALLET,B_BANK,B_OVERAGE billing
